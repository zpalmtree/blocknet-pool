name = "blocknet-pool-monitor"
main = "worker.js"
compatibility_date = "2026-03-08"

[triggers]
crons = ["* * * * *"]

[[kv_namespaces]]
binding = "MONITOR_STATE"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

[vars]
PUBLIC_MONITOR_URL = "https://bntpool.com/api/monitor/public"
INGEST_URL = "https://bntpool.com/api/monitor/ingest/cloudflare"

# Set these as Wrangler secrets:
#   wrangler secret put INGEST_SECRET
#   wrangler secret put DISCORD_WEBHOOK_URL
