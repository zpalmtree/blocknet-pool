[Unit]
Description=Blocknet Pool Monitor
After=network-online.target nginx.service postgresql.service blocknet-pool-api.service blocknet-pool-stratum.service blocknet-pool-recoveryd.socket
Wants=network-online.target nginx.service postgresql.service blocknet-pool-recoveryd.socket

[Service]
Type=simple
User=blocknet
Group=blocknet
WorkingDirectory=/opt/blocknet/blocknet-pool
EnvironmentFile=/etc/blocknet/pool/.env
EnvironmentFile=-/etc/blocknet/monitoring.env
ExecStart=/opt/blocknet/blocknet-pool/target/release/blocknet-pool-monitor --config /etc/blocknet/pool/config.json
Restart=always
RestartSec=5
LimitNOFILE=65535
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/blocknet-pool /etc/blocknet/pool

[Install]
WantedBy=multi-user.target
